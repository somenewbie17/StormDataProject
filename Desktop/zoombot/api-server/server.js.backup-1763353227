/**
 * GET /api/recordings
 * Get recordings for a user (filtered by access level and permissions)
 * 
 * Query params:
 * - userId: User ID (mock for now, will come from JWT token later)
 * - courseCode: Optional filter by course (e.g., "LAW2109")
 * - classDate: Optional ISO date string for the class session (e.g., "2025-11-18")
 * - classTime: Optional time in HH:MM format (e.g., "17:15")
 * - timeWindow: Optional time window in minutes (default: 120 = ±2 hours)
 */
app.get('/api/recordings', async (req, res) => {
  try {
    const { userId, courseCode, classDate, classTime, timeWindow } = req.query;
    
    if (!userId) {
      return res.status(400).json({ error: 'userId required' });
    }

    // Get user to check tier
    const user = await prisma.user.findUnique({
      where: { id: userId }
    });

    if (!user) {
      return res.status(404).json({ error: 'User not found' });
    }

    // Build query based on user tier
    let where = { 
      status: { in: ['ready', 'done'] } // Accept both ready and done statuses
    };
    
    if (courseCode) {
      where.courseCode = courseCode;
    }

    // Time-based filtering (optional)
    // ⚠️ CRITICAL: Use UTC consistently to prevent timezone shifts!
    if (classDate && classTime) {
      const windowMinutes = parseInt(timeWindow) || 120; // Default 2 hours
      
      // Parse class date and time in UTC (add Z to force UTC interpretation!)
      const [hours, minutes] = classTime.split(':').map(Number);
      const classDateTime = new Date(classDate + 'T00:00:00Z'); // Z = UTC!
      classDateTime.setUTCHours(hours, minutes, 0, 0); // Use UTC methods!
      
      // Calculate time window
      const startTime = new Date(classDateTime.getTime() - windowMinutes * 60 * 1000);
      const endTime = new Date(classDateTime.getTime() + windowMinutes * 60 * 1000);
      
      where.recordedAt = {
        gte: startTime,
        lte: endTime
      };
    }

    // TIER-BASED ACCESS CONTROL
    let recordings;
    
    if (user.tier === 'free') {
      // Free users: Get recordings but strip full content (only AI chapters)
      recordings = await prisma.recording.findMany({ where });
      
      // Remove video/audio/transcript paths - Free users only get AI chapters
      recordings = recordings.map(rec => ({
        ...rec,
        videoPath: null,
        audioPath: null,
        transcriptPath: null,
        _accessLevel: 'chapters-only' // Flag for frontend
      }));
      
    } else if (user.tier === 'pro') {
      // Pro users: ONLY their registered program
      if (!user.registeredProgram) {
        return res.status(403).json({ 
          error: 'No program registered',
          message: 'Pro tier requires program selection. Please select your program.',
          action: 'select_program'
        });
      }
      
      // Filter by user's registered program
      where.program = user.registeredProgram;
      recordings = await prisma.recording.findMany({ where });
      
      console.log(`🎓 Pro user (${user.email}) accessing program: ${user.registeredProgram}`);
      
    } else if (user.tier === 'premium') {
      // Premium users: ALL recordings across all programs
      recordings = await prisma.recording.findMany({ where });
      console.log(`👑 Premium user (${user.email}) accessing all recordings`);
      
    } else {
      // Invalid/unknown tier
      return res.status(403).json({ 
        error: 'Invalid subscription tier',
        message: 'Please upgrade to access recordings'
      });
    }

    res.json(recordings);
  } catch (error) {
    console.error('Error fetching recordings:', error);
    res.status(500).json({ error: 'Failed to fetch recordings' });
  }
});

/**
 * GET /api/recordings/:id
 * Get single recording details
 */
app.get('/api/recordings/:id', async (req, res) => {
  try {
    const { id } = req.params;
    const { userId } = req.query;

    if (!userId) {
      return res.status(400).json({ error: 'userId required' });
    }

    const recording = await prisma.recording.findUnique({
      where: { id }
    });

    if (!recording) {
      return res.status(404).json({ error: 'Recording not found' });
    }

    // Check access
    const user = await prisma.user.findUnique({
      where: { id: userId }
    });

    const hasAccess = user.tier === 'enterprise' || 
                     await prisma.userRecordingAccess.findFirst({
                       where: { userId, recordingId: id }
                     });

    if (!hasAccess) {
      return res.status(403).json({ error: 'Access denied' });
    }

    res.json(recording);
  } catch (error) {
    console.error('Error fetching recording:', error);
    res.status(500).json({ error: 'Failed to fetch recording' });
  }
});

/**
 * PATCH /api/recordings/:id
 * Update recording metadata (courseCode, courseName, etc.)
 */
app.patch('/api/recordings/:id', async (req, res) => {
  try {
    const { id } = req.params;
    const { courseCode, courseName, status, accessLevel, recordedAt, duration } = req.body;

    const recording = await prisma.recording.findUnique({
      where: { id }
    });

    if (!recording) {
      return res.status(404).json({ error: 'Recording not found' });
    }

    // Build update data
    const updateData = {};
    if (courseCode !== undefined) updateData.courseCode = courseCode;
    if (courseName !== undefined) updateData.courseName = courseName;
    if (status !== undefined) updateData.status = status;
    if (accessLevel !== undefined) updateData.accessLevel = accessLevel;
    if (recordedAt !== undefined) updateData.recordedAt = new Date(recordedAt);
    if (duration !== undefined) updateData.duration = duration;
    updateData.updatedAt = new Date();

    const updatedRecording = await prisma.recording.update({
      where: { id },
      data: updateData
    });

    res.json(updatedRecording);
  } catch (error) {
    console.error('Error updating recording:', error);
    res.status(500).json({ error: 'Failed to update recording' });
  }
});

/**
 * POST /api/recordings
 * Create new recording (called by webhook-server.mjs)
 */
app.post('/api/recordings', async (req, res) => {
  try {
    const {
      botId,
      courseCode,
      courseName,
      program,
      recordedAt,
      duration,
      videoPath,
      audioPath,
      transcriptPath,
      status = 'ready',
      accessLevel = 'premium',
      metadata
    } = req.body;

    // Validation
    if (!botId || !courseCode || !courseName) {
      return res.status(400).json({ 
        error: 'botId, courseCode, and courseName are required' 
      });
    }

    // Create or update recording
    const recording = await prisma.recording.upsert({
      where: { botId },
      create: {
        botId,
        courseCode,
        courseName,
        program: program || 'general',
        recordedAt: recordedAt ? new Date(recordedAt) : new Date(),
        duration: duration || 0,
        videoPath: videoPath || '',
        audioPath: audioPath || null,
        transcriptPath,
        status,
        accessLevel,
        metadata: metadata ? JSON.stringify(metadata) : null
      },
      update: {
        program: program || undefined,
        status,
        videoPath: videoPath || undefined,
        audioPath: audioPath || undefined,
        transcriptPath: transcriptPath || undefined,
        duration: duration || undefined
      }
    });

    // Auto-grant access to all premium/enterprise users for this course
    // (You can customize this logic based on course enrollments)
    const eligibleUsers = await prisma.user.findMany({
      where: {
        tier: { in: ['premium', 'enterprise'] }
      }
    });

    // Grant access to all eligible users
    for (const user of eligibleUsers) {
      await prisma.userRecordingAccess.upsert({
        where: {
          userId_recordingId: {
            userId: user.id,
            recordingId: recording.id
          }
        },
        create: {
          userId: user.id,
          recordingId: recording.id
        },
        update: {}
      });
    }

    res.status(201).json(recording);
  } catch (error) {
    console.error('Error creating recording:', error);
    res.status(500).json({ error: 'Failed to create recording' });
  }
});

